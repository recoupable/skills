# Resolver-eval fixtures for recoup-records. One JSON object per line.
# {"intent": <real user phrasing>, "expected": <skill that must own it>, "not": [<skills that must NOT fire>]}
# Run: python3 scripts/run_resolver_eval.py   (structural tier; set RECOUP_RESOLVER_EVAL_LLM=1 for the routing tier)
# Every skill needs >=1 positive here (coverage is enforced). Add a fixture when you add a skill.

# --- Domain 1: setup & account ---
{"intent": "set me up, verify my email and give me an api key", "expected": "recoup-setup"}
{"intent": "scaffold the sandbox file system from my orgs and artists", "expected": "recoup-setup-sandbox"}
{"intent": "fetch this artist's socials from the recoup api", "expected": "recoup-api"}
{"intent": "create a new artist account for Mvney", "expected": "recoup-artist-create", "not": ["recoup-artist-workspace"]}
{"intent": "set up the folder structure inside this artist's directory", "expected": "recoup-artist-workspace", "not": ["recoup-artist-create"]}
{"intent": "that worked, remember this so we don't redo it next time", "expected": "recoup-learn"}

# --- Domain 2: research & A&R ---
{"intent": "research Drake and give me an overview", "expected": "recoup-artist-research"}
{"intent": "where are this artist's fans and what markets should we expand into", "expected": "recoup-artist-audience"}
{"intent": "compare these two artists and find collaborators", "expected": "recoup-artist-competition"}
{"intent": "find emerging unsigned artists in the afrobeats scene", "expected": "recoup-artist-scout"}
{"intent": "what playlists should this artist's catalog target and where are the gaps", "expected": "recoup-artist-playlists", "not": ["recoup-song-pitch-kit"]}
{"intent": "find me A&R reps and press contacts and draft outreach", "expected": "recoup-artist-outreach"}
{"intent": "which of this artist's songs are blowing up on tiktok", "expected": "recoup-artist-tiktok"}
{"intent": "there's no structured data, dig up narrative context from the web", "expected": "recoup-web-intelligence", "not": ["recoup-artist-research"]}
{"intent": "enrich this record label with structured facts and recent news", "expected": "recoup-web-intelligence", "not": ["recoup-artist-research"]}

# --- Domain 3: monitors (scheduled) ---
{"intent": "give me the weekly brief on what's new with this artist", "expected": "recoup-artist-brief", "not": ["recoup-release-brief"]}
{"intent": "are this artist's streams spiking or dropping vs last check", "expected": "recoup-artist-brief"}
{"intent": "monitor for the single dropping and alert me on launch day", "expected": "recoup-release-monitor"}

# --- Domain 4: song audio analysis ---
{"intent": "analyze this track's audio, give me bpm key genre and a mix critique", "expected": "recoup-song-analyze"}
{"intent": "find the best 15 seconds of this song to clip for a reel", "expected": "recoup-song-hook", "not": ["recoup-content-video"]}
{"intent": "write a playlist pitch and a sync brief for this single from the audio", "expected": "recoup-song-pitch-kit", "not": ["recoup-artist-playlists"]}
{"intent": "help me write lyrics and sharpen the hook for this unfinished song", "expected": "recoup-songwriting", "not": ["recoup-song-hook"]}

# --- Domain 5: content creation ---
{"intent": "make me something for this artist's launch", "expected": "recoup-content"}
{"intent": "write an instagram caption in this artist's voice", "expected": "recoup-content-caption"}
{"intent": "make a tiktok video of the artist with their song", "expected": "recoup-content-video", "not": ["recoup-content-lyric-video", "recoup-content-visualizer"]}
{"intent": "make a lyric video with the words on screen timed to the song", "expected": "recoup-content-lyric-video", "not": ["recoup-content-video"]}
{"intent": "make a looping spotify canvas with no text", "expected": "recoup-content-visualizer", "not": ["recoup-content-video"]}
{"intent": "make square cover art for the single for spotify", "expected": "recoup-content-image", "not": ["recoup-content-video"]}
{"intent": "make a 16:9 youtube thumbnail with a hook line", "expected": "recoup-content-image"}
{"intent": "make an out-now announcement promo graphic", "expected": "recoup-content-image"}
{"intent": "make a carousel photo dump and a quote card", "expected": "recoup-content-image"}
{"intent": "they just crossed 1B streams, make something off that", "expected": "recoup-content-trend", "not": ["recoup-artist-brief"]}
{"intent": "give me a streaming health check on this artist", "expected": "recoup-artist-brief"}
{"intent": "give me a whole content pack, 30 posts for the launch", "expected": "recoup-content-pack"}
{"intent": "reformat this master video for tiktok reels and shorts", "expected": "recoup-content-reformat"}

# --- Domain 6: catalog deals ---
{"intent": "run a full diligence review on this catalog deal", "expected": "recoup-deal-start"}
{"intent": "show me the deal demo on the synthetic catalog", "expected": "recoup-deal-demo"}
{"intent": "ingest and normalize this messy royalty data room", "expected": "recoup-deal-ingest"}
{"intent": "value this catalog from the ingested seller files", "expected": "recoup-deal-value", "not": ["recoup-catalog-value"]}
{"intent": "build the executive dashboard html for this deal", "expected": "recoup-deal-dashboard"}
{"intent": "write the IC memo and turn it into a shareable pdf", "expected": "recoup-deal-report"}
{"intent": "estimate this catalog's value from public streaming data, I have no seller files", "expected": "recoup-catalog-value", "not": ["recoup-deal-value", "recoup-deal-ingest"]}

# --- Domain 7: releases ---
{"intent": "start a release and take it end to end", "expected": "recoup-release-start"}
{"intent": "show me the release workflow demo", "expected": "recoup-release-demo"}
{"intent": "give me a pre-release creative brief with concept directions", "expected": "recoup-release-brief", "not": ["recoup-artist-brief"]}
{"intent": "create the RELEASE.md master doc and the DSP pitch", "expected": "recoup-release-doc"}
{"intent": "build the dated rollout schedule for the single", "expected": "recoup-release-campaign", "not": ["recoup-release-brief"]}
